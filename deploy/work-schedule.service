[Unit]
Description=Work Schedule Django application
After=network.target docker.service

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/work_schedule/app/core
EnvironmentFile=/opt/work_schedule/.env
ExecStart=/opt/work_schedule/venv/bin/gunicorn core.wsgi:application --bind 172.18.0.1:8000 --workers 2 --timeout 120
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
